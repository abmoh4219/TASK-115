FROM mcr.microsoft.com/playwright:v1.59.1-jammy
WORKDIR /app
COPY package*.json ./
RUN npm ci --include=dev
COPY . .
# Resolve app hostname to IP and wait for readiness, then run tests using IP
CMD ["bash", "-c", "echo 'Waiting for app...'; until bash -c 'exec 3<>/dev/tcp/app/80' 2>/dev/null; do sleep 2; done; APP_IP=$(getent hosts app | awk '{print $1}'); echo \"App ready at $APP_IP\"; E2E_BASE_URL=http://$APP_IP:80 node_modules/.bin/playwright test --reporter=list"]
