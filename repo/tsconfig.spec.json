{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": [
      "jest",
      "node"
    ],
    "esModuleInterop": true,
    "paths": {
      "@core/*": ["src/app/core/*"],
      "@shared/*": ["src/app/shared/*"],
      "@features/*": ["src/app/features/*"]
    }
  },
  "include": [
    "src/**/*.spec.ts",
    "unit_tests/**/*.spec.ts",
    "api_tests/**/*.spec.ts",
    "src/**/*.d.ts",
    "setup-jest.ts"
  ]
}
